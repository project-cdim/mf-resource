# This file is a configuration file for the development environment of `Next.js`.
# If you are not developing this component, no configuration is required.

# API endpoint of the backend for Configuration Manager
# NEXT_PUBLIC_URL_BE_CONFIGURATION_MANAGER = 'http://localhost/infrastructure-config-sw/api/v1'

# API endpoint of the backend for Performance Manager (VictoriaMetrics)
# NEXT_PUBLIC_URL_BE_PERFORMANCE_MANAGER = 'http://localhost/api/v1'

# Use Mock Service Worker in environments other than development
# Note: Changes to these variables require a dev server restart (npm run dev)
# NEXT_PUBLIC_USE_MSW = 'false'

# Selectively enable/disable MSW mocking by resource type
# Set to 'true' to enable mocking for specific resource types
# Default: all groups are disabled (false)
# Note: Changes to these variables require a dev server restart (npm run dev)
# NEXT_PUBLIC_MSW_MOCK_RACKS = 'true'
# NEXT_PUBLIC_MSW_MOCK_NODES = 'true'
# NEXT_PUBLIC_MSW_MOCK_RESOURCES = 'true'
# NEXT_PUBLIC_MSW_MOCK_DEVICE_UNITS = 'true'
# NEXT_PUBLIC_MSW_MOCK_RESOURCE_GROUPS = 'true'
# NEXT_PUBLIC_MSW_MOCK_CXL_SWITCHES = 'true'
# NEXT_PUBLIC_MSW_MOCK_PERFORMANCE = 'true'
